			IceCream: {
				DisplayName: Мороженое
				Tooltip:
					'''
					Каждый Восьмой удар по врагу Стендом будет крит. ударом.
					70% к урону от крит. удара Стенда. -10% к шансу Стенда на крит. удар.
					'''
			}

			Polaroid: {
				DisplayName: Полароид
				Tooltip:
					'''
					Убийства Стендами могут накапливать до 5 символов. Символы снижают урон на 50% за каждое попадание.
					Позволяет атакам Стенда красть жизнь.
					40% к урону по владельцу при отсутствии символа.
					Получение символов имеет перезарядку в 5с.
					'''
			}

			StickyHand: {
				DisplayName: Стики-Рука
				Tooltip:
					'''
					20% к шансу Стенда на уворот и удвоение бонуса защиты от Стенда.
					Здоровье медленно утекает 30с после получения урона.
					Позволяет вам дать последний бой перед смертью.
					Во время 'Последнего Боя', урон и шанс на крит. удар удвоены.
					'''
			}

			Teacup: {
				DisplayName: Чашка травяного чая
				Tooltip:
					'''
					10 следующие дальних атак Стенда будут усилены, восстанавливая по одной атаке каждую секунду при отдыхе.
					Урон от Стенда увеличен на 3% за каждого врага поблизости и еще 12%, если призван босс.
					'''
			}

			ViralPearlEarring: {
				DisplayName: Сережка с Вирусной Жемчужиной
				Tooltip:
					'''
					Атакуя врагов Стендом, 10% от нанесенного им урона будет переноситься и на близкостоящих врагов.
					Перенесенный урон будет удвоен, если вы долгое время не получали урон.
					Ударяя врагов Стендом, есть шанс заразить их вирусом.
					'''
			}

