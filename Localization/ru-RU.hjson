				SecretReferences: {
					Label: Скрытые Отсылки
					Tooltip: Определяет, хотите вы видеть скрытые отсылки или нет. (Некоторые из этих отсылок могут привести к вашей смерти!)
				}

				RangeIndicatorVisibility: {
